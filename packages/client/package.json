{
  "name": "@typoon/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client runtime for realtime manga translation overlays.",
  "main": "src/web-reader.ts",
  "types": "dist/web-reader.d.ts",
  "exports": {
    "./web-reader": {
      "types": "./dist/web-reader.d.ts",
      "default": "./src/web-reader.ts"
    }
