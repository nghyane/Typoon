    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:types": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "chrome-lens-ocr": "^4.1.1",
    "comlink": "^4.4.2",
    "onnxruntime-web": "^1.26.0"
  }
}
