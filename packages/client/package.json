{
  "name": "@typoon/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client runtime for realtime manga translation overlays.",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    "./web-reader": {
      "types": "./dist/web-reader.d.ts",
      "default": "./src/web-reader.ts"
    },
    "./vision/vision.worker.ts": "./src/vision/vision.worker.ts"
  },
  "scripts": {
    "dev": "vite dev",
    "generate:analysis": "../../.venv/bin/python scripts/generate-dev-analysis.py",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:types": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "chrome-lens-ocr": "^4.1.1",
    "comlink": "^4.4.2",
    "onnxruntime-web": "^1.26.0"
  }
}
