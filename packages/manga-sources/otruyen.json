{
  "id":        "otruyen",
  "name":      "OTruyen",
  "host":      "otruyenapi.com",
  "homepage":  "https://otruyen.cc",
  "languages": ["vi"],
  "version":   "2.3",
  "accent":    "emerald",

  "defaults": { "genre": "action" },

  "endpoints": {
    "shelves": [
      {
        "id":    "latest",
        "label": "Mới cập nhật",
        "endpoint": {
          "method": "GET",
          "url":    "https://otruyenapi.com/v1/api/danh-sach/truyen-moi?page={page}",
          "parse":  "json",
          "pagination": { "type": "page", "pageSize": 24 },
          "list":   "$.data.items[*]",
          "rootExtras": {
            "cdn": "$.data.APP_DOMAIN_CDN_IMAGE"
          },
          "extras": {
            "thumb": "@thumb_url",
            "slug":  "@slug"
          },
          "fields": {
            "title": "@name",
            "url":   "=https://otruyenapi.com/v1/api/truyen-tranh/{slug}",
            "cover": "={cdn}/uploads/comics/{thumb}"
          }
        }
      },
      {
        "id":    "ongoing",
        "label": "Đang ra",
        "endpoint": {
          "method": "GET",
          "url":    "https://otruyenapi.com/v1/api/danh-sach/dang-phat-hanh?page={page}",
          "parse":  "json",
          "pagination": { "type": "page", "pageSize": 24 },
          "list":   "$.data.items[*]",
          "rootExtras": {
            "cdn": "$.data.APP_DOMAIN_CDN_IMAGE"
          },
          "extras": {
            "thumb": "@thumb_url",
            "slug":  "@slug"
          },
          "fields": {
            "title": "@name",
            "url":   "=https://otruyenapi.com/v1/api/truyen-tranh/{slug}",
            "cover": "={cdn}/uploads/comics/{thumb}"
          }
        }
      },
      {
        "id":    "completed",
        "label": "Đã hoàn thành",
        "endpoint": {
          "method": "GET",
          "url":    "https://otruyenapi.com/v1/api/danh-sach/hoan-thanh?page={page}",
          "parse":  "json",
          "pagination": { "type": "page", "pageSize": 24 },
          "list":   "$.data.items[*]",
          "rootExtras": {
            "cdn": "$.data.APP_DOMAIN_CDN_IMAGE"
          },
          "extras": {
            "thumb": "@thumb_url",
            "slug":  "@slug"
          },
          "fields": {
            "title": "@name",
            "url":   "=https://otruyenapi.com/v1/api/truyen-tranh/{slug}",
            "cover": "={cdn}/uploads/comics/{thumb}"
          }
        }
      },
      {
        "id":    "genre",
        "label": "Thể loại",
        "filters": [
          {
            "id":    "genre",
            "label": "Thể loại",
            "type":  "select",
            "inject": "path",
            "options": [
              { "id": "action",        "label": "Action",        "param": "action" },
              { "id": "adventure",     "label": "Adventure",     "param": "adventure" },
              { "id": "chuyen-sinh",   "label": "Chuyển Sinh",   "param": "chuyen-sinh" },
              { "id": "comedy",        "label": "Comedy",        "param": "comedy" },
              { "id": "co-dai",        "label": "Cổ Đại",        "param": "co-dai" },
              { "id": "drama",         "label": "Drama",         "param": "drama" },
              { "id": "fantasy",       "label": "Fantasy",       "param": "fantasy" },
              { "id": "gender-bender", "label": "Gender Bender", "param": "gender-bender" },
              { "id": "harem",         "label": "Harem",         "param": "harem" },
              { "id": "historical",    "label": "Historical",    "param": "historical" },
              { "id": "horror",        "label": "Horror",        "param": "horror" },
              { "id": "manhua",        "label": "Manhua",        "param": "manhua" },
              { "id": "manhwa",        "label": "Manhwa",        "param": "manhwa" },
              { "id": "martial-arts",  "label": "Martial Arts",  "param": "martial-arts" },
              { "id": "mystery",       "label": "Mystery",       "param": "mystery" },
              { "id": "ngon-tinh",     "label": "Ngôn Tình",     "param": "ngon-tinh" },
              { "id": "psychological", "label": "Psychological", "param": "psychological" },
              { "id": "romance",       "label": "Romance",       "param": "romance" },
              { "id": "school-life",   "label": "School Life",   "param": "school-life" },
              { "id": "sci-fi",        "label": "Sci-fi",        "param": "sci-fi" },
              { "id": "seinen",        "label": "Seinen",        "param": "seinen" },
              { "id": "shoujo",        "label": "Shoujo",        "param": "shoujo" },
              { "id": "shounen",       "label": "Shounen",       "param": "shounen" },
              { "id": "slice-of-life", "label": "Slice of Life", "param": "slice-of-life" },
              { "id": "supernatural",  "label": "Supernatural",  "param": "supernatural" },
              { "id": "tragedy",       "label": "Tragedy",       "param": "tragedy" },
              { "id": "trinh-tham",    "label": "Trinh Thám",    "param": "trinh-tham" },
              { "id": "truyen-mau",    "label": "Truyện Màu",    "param": "truyen-mau" },
              { "id": "webtoon",       "label": "Webtoon",       "param": "webtoon" },
              { "id": "xuyen-khong",   "label": "Xuyên Không",   "param": "xuyen-khong" },
              { "id": "dam-my",        "label": "Đam Mỹ",        "param": "dam-my" },
              { "id": "ecchi",         "label": "Ecchi",         "param": "ecchi" },
              { "id": "mature",        "label": "Mature",        "param": "mature" },
              { "id": "smut",          "label": "Smut",          "param": "smut" }
            ]
          }
        ],
        "endpoint": {
          "method": "GET",
          "url":    "https://otruyenapi.com/v1/api/the-loai/{filterPath}?page={page}",
          "parse":  "json",
          "pagination": { "type": "page", "pageSize": 24 },
          "list":   "$.data.items[*]",
          "rootExtras": {
            "cdn": "$.data.APP_DOMAIN_CDN_IMAGE"
          },
          "extras": {
            "thumb": "@thumb_url",
            "slug":  "@slug"
          },
          "fields": {
            "title": "@name",
            "url":   "=https://otruyenapi.com/v1/api/truyen-tranh/{slug}",
            "cover": "={cdn}/uploads/comics/{thumb}"
          }
        }
      }
    ],

    "search": {
      "method": "GET",
      "url":    "https://otruyenapi.com/v1/api/tim-kiem?keyword={q:q}",
      "parse":  "json",
      "list":   "$.data.items[*]",
      "rootExtras": {
        "cdn": "$.data.APP_DOMAIN_CDN_IMAGE"
      },
      "extras": {
        "thumb": "@thumb_url",
        "slug":  "@slug"
      },
      "fields": {
        "title": "@name",
        "url":   "=https://otruyenapi.com/v1/api/truyen-tranh/{slug}",
        "cover": "={cdn}/uploads/comics/{thumb}"
      }
    },

    "manga": {
      "method":  "GET",
      "url":     "{mangaUrl}",
      "parse":   "json",
      "extract": "/truyen-tranh/(?<slug>[^/?#]+)",
      "rootExtras": {
        "cdn":   "$.data.APP_DOMAIN_CDN_IMAGE",
        "thumb": "$.data.item.thumb_url"
      },
      "fields": {
        "title":       "$.data.item.name",
        "description": "$.data.item.content",
        "author":      "$.data.item.author[0]",
        "status":      "$.data.item.status",
        "cover":       "={cdn}/uploads/comics/{thumb}",
        "updatedAt":   "$.data.item.updatedAt"
      },
      "chapters": {
        "list":   "$.data.item.chapters[0].server_data[*]",
        "fields": {
          "number": "@chapter_name",
          "title":  "@chapter_title",
          "url":    "@chapter_api_data"
        }
      }
    },

    "chapter": {
      "method": "GET",
      "url":    "{chapterUrl}",
      "parse":  "json",
      "pages": {
        "extras": {
          "cdn":   "$.data.domain_cdn",
          "path":  "$.data.item.chapter_path",
          "files": "$.data.item.chapter_image[*]@image_file"
        },
        "iterate":  "files",
        "template": "{cdn}/{path}/{file}"
      }
    }
  }
}
