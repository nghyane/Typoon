# Discord OAuth/role entitlement. Public IDs only; do not put secrets in VITE_*.
# Enable Public Client / PKCE in Discord Developer Portal for browser login.
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_GUILD_ID=
VITE_DISCORD_PROXY_BASE=/discord

# Comma-separated role IDs. Leave blank to authenticate users as free.
VITE_DISCORD_PRO_ROLE_IDS=
VITE_DISCORD_VIP_ROLE_IDS=

# How long cached entitlement can be used when Discord cannot be checked.
VITE_DISCORD_CACHE_GRACE_HOURS=168
