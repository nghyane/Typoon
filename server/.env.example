# Server
PORT=3000
DATABASE_URL=postgres:///typoon_test?sslmode=disable

# Discord OAuth (PWA + DA)
# Redirect URL must be added to Discord Developer Portal → OAuth2 → Redirects
# Dev: http://localhost:5173/auth/callback (FE receives code+state, then POSTs to BE)
DISCORD_CLIENT_ID=927251094806098001
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=http://localhost:5173/auth/callback
# Discord Activity SDK authorize uses this redirect URI for token exchange.
DISCORD_ACTIVITY_REDIRECT_URL=https://127.0.0.1

# CORS — comma-separated allowed origins
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# LLM (OpenAI-compatible)
# Protocol: openai_chat_completions (/v1/chat/completions) or openai_responses (/v1/responses)
LLM_API_KEY=
LLM_MODEL=gpt-5.4-mini
LLM_BASE_URL=http://localhost:8090/v1
LLM_PROTOCOL=openai_responses
LLM_TIMEOUT_MS=60000

# PayOS (payment)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
