# Dev env — Vite loads .env.development before .env.production in `bun dev`.
# Single base URL for all upstream calls (api, files, cdn, /t archives).
# Inside DA iframe (hostname *.discordsays.com) the code automatically
# uses same-origin paths and ignores this — it only kicks in for plain
# web (localhost dev, mangalocal.com preview, etc.) which can't proxy
# through Discord's URL Mappings.
VITE_PUBLIC_BASE_URL=
VITE_DISCORD_CLIENT_ID=927251094806098001
VITE_DEV_API=https://typoon-api.hoangvananhnghia99.workers.dev
