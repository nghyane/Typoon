# GitHub Packages routing for @nghyane/bunle.
#
# Public on GitHub Packages but install still requires auth. Contributors
# export GITHUB_TOKEN before `bun install`:
#
#   export GITHUB_TOKEN=$(gh auth token)
#
# CI: `actions/setup-node` with `registry-url` does this automatically.
@nghyane:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
