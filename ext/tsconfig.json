{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@core/*":   ["core/*"],
      "@shell/*":  ["shell/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["./globals.d.ts"]
}
