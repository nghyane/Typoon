# Typoon config — Cloudflare AI Gateway
# Copy to config.toml and customize.

models_dir = "models"
default_target_lang = "vi"

[providers.cf]
type = "openai"
# Cloudflare AI Gateway — OpenAI-compatible compat endpoint
# Set api_key = "" to skip Authorization (SDK will not inject a key).
# The CF token is passed via cf-aig-authorization.
endpoint = "https://gateway.ai.cloudflare.com/v1/<account-id>/<gateway-name>/compat"
api_key = ""
extra_headers = { cf-aig-authorization = "Bearer <your-cf-aig-token>" }

[translation]
provider = "cf"
model = "dynamic/auto"   # Gateway auto-routes; requires endpoint compat path

[context_agent]
provider = "cf"
model = "dynamic/auto"

# Alternative: direct OpenAI
# [providers.openai]
# type = "openai"
# api_key = "sk-..."
#
# [translation]
# provider = "openai"
# model = "gpt-4o-mini"

# Alternative: MiniMax (Anthropic-compatible API with prompt caching)
# Uses Anthropic SDK — base_url points to MiniMax endpoint.
# Supports cache_control (ephemeral, 5-min lifetime) on system + tools prefix.
# Models: MiniMax-M2.7, MiniMax-M2.7-highspeed, MiniMax-M2.5, MiniMax-M2.5-highspeed
#
# [providers.minimax]
# type = "anthropic"
# endpoint = "https://api.minimax.io/anthropic"
# api_key = "$MINIMAX_API_KEY"
#
# [translation]
# provider = "minimax"
# model = "MiniMax-M2.7"
#
# [context_agent]
# provider = "minimax"
# model = "MiniMax-M2.5"    # cheaper model for context phase
