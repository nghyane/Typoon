# Typoon config — Cloudflare AI Gateway
# Copy to config.toml and customize.

models_dir = "models"
default_target_lang = "vi"

# Vision pipeline composition. Pick a preset OR override per-stage.
# Presets (see typoon/vision/pipeline.py PRESETS):
#   lens          — Lens detector + native grouper, recognizer skipped.
#                   Default. Best multilingual coverage, recall.
#   lens_balanced — same stages, page_concurrency=8, detect_concurrency=15.
#   bing          — Bing OCR + YOLO bubble grouper. Use when Lens
#                   endpoint is rate-limited or unreachable from your
#                   region; Bing returns line-level boxes so YOLO
#                   bubble-scope merges them into bubbles.
#   offline       — PP-OCR DBNet + YOLO + Apple Vision. No network.
#   manga_ja      — PP-OCR + YOLO + manga-ocr (Japanese-optimised).
#
# [vision]
# preset = "lens"
#
# Optional per-stage overrides applied on top of the preset:
# detector            = "bing_blocks"
# grouper             = "ppocr_yolo_union_find"
# recognizer          = "none"
# eraser              = "aot_gan"
# page_concurrency    = 4
# detect_concurrency  = 8
# erase_concurrency   = 2

# Override the Google Lens upstream endpoint. Empty = library default
# (https://lensfrontend-pa.googleapis.com/v1/crupload). Setting this to
# a Discord Activity proxy URL routes through Cloudflare's edge:
# measured 30–50% faster from APAC than the direct Google endpoint and
# noticeably lower variance. Requires the application's URL Mappings
# to map `/lens` → `lensfrontend-pa.googleapis.com` in the Developer
# Portal. Same effect via env: `LENS_ENDPOINT=...`.
# lens_endpoint = "https://<application_id>.discordsays.com/lens/v1/crupload"

# Bing OCR (preset = "bing") talks to bing.com directly. Discord
# Activity URL Mappings cannot proxy Bing because the upload step
# returns a 302 with `insightsToken` in the query string, and CF Worker
# `fetch()` auto-follows the redirect, losing the token. APAC users
# pay direct latency.

[providers.cf]
type = "openai"
# Cloudflare AI Gateway — OpenAI-compatible compat endpoint
# Set api_key = "" to skip Authorization (SDK will not inject a key).
# The CF token is passed via cf-aig-authorization.
endpoint = "https://gateway.ai.cloudflare.com/v1/<account-id>/<gateway-name>/compat"
api_key = ""
extra_headers = { cf-aig-authorization = "Bearer <your-cf-aig-token>" }
# Maximum in-flight requests against this provider, shared across
# every agent that resolves to it (context, translate, vision).
# Default 24 sized for paid Tier 1 (OpenAI 500 RPM / Anthropic Tier 1)
# at ~3s/call latency (Little's law: 8 RPS × 3s ≈ 24).
#   2     — free tier (Gemini free, OpenRouter free)
#   24    — paid Tier 1 (default)
#   64    — paid Tier 2+ (2000+ RPM)
#   0     — disable gate; rely solely on provider rate limit + retry/backoff.
#
# Note: Cloudflare AI Gateway does NOT throttle by default; the
# upstream provider's tier is the real ceiling. If you configure a
# gateway-level rate_limiting_limit on the CF dashboard, lower this
# value so 24 × ~3s ≈ 8 RPS stays under your CF window.
# concurrency = 24

# OpenAI endpoint shape — "chat" (default, /v1/chat/completions) or
# "responses" (/v1/responses). Set "responses" for local proxies /
# modern OpenAI-compatible servers that only speak the Responses API.
# api_kind = "chat"

[translation]
provider = "cf"
model = "dynamic/auto"   # Gateway auto-routes; requires endpoint compat path

[vision_agent]
# Drives the per-chapter storyboard context pass (replaces the old
# context_agent multi-turn loop) and on-demand look_at calls. The
# storyboard pass sends ONE image + bubble list per chunk of up to 9
# pages, so the provider must support image inputs (OpenAI-compatible
# Responses API, Anthropic, or Gemini).
provider = "cf"
model = "dynamic/auto"

# Alternative: direct OpenAI
# [providers.openai]
# type = "openai"
# api_key = "sk-..."
#
# [translation]
# provider = "openai"
# model = "gpt-4o-mini"

# Alternative: MiniMax (Anthropic-compatible API with prompt caching)
# Uses Anthropic SDK — base_url points to MiniMax endpoint.
# Supports cache_control (ephemeral, 5-min lifetime) on system + tools prefix.
# Models: MiniMax-M2.7, MiniMax-M2.7-highspeed, MiniMax-M2.5, MiniMax-M2.5-highspeed
#
# [providers.minimax]
# type = "anthropic"
# endpoint = "https://api.minimax.io/anthropic"
# api_key = "$MINIMAX_API_KEY"
#
# [translation]
# provider = "minimax"
# model = "MiniMax-M2.7"
#
# [vision_agent]
# provider = "minimax"
# model = "MiniMax-M2.5"    # cheaper model for context phase

# Alternative: Gemini Web (reverse-engineered gemini.google.com).
# Uses your Google One AI Pro account quota instead of the paid Gemini
# API tier. Requires `pip install gemini-webapi browser-cookie3`.
# No tool/function calling support: configure this provider only for
# stages that pass an empty tools list — currently `translation` and
# `vision_agent` both do.
#
# Cookie sourcing: either paste __Secure-1PSID/-1PSIDTS inline, or
# point `cookie_browser` at a logged-in profile and let the auto-loader
# pick them up.
#
# Models (Plus tier subset shown — see typoon/llm/gemini_web.py for full list):
#   gemini-3-pro          gemini-3-flash          gemini-3-flash-thinking
#   gemini-3-pro-plus     gemini-3-flash-plus     gemini-3-flash-thinking-plus
#   auto                  (let Gemini pick the account's default)
#
# [providers.gemini_web]
# type           = "gemini_web"
# cookie_browser = "edge"           # or paste values below
# # secure_1psid   = "$GEMINI_1PSID"
# # secure_1psidts = "$GEMINI_1PSIDTS"
# # Web Gemini is per-account; the server tolerates parallel one-shot
# # turns surprisingly well — we measured 8 concurrent translate windows
# # going through cleanly on a Plus account with no rate-limit kicks.
# # Per-call latency dominates wall time (6–40 s/call), so going much
# # higher than the number of windows in a typical chapter buys nothing.
# concurrency = 8
#
# [translation]
# provider = "gemini_web"
# model    = "auto"
#
# [vision_agent]
# provider = "gemini_web"
# model    = "auto"                 # or "gemini-3-pro-plus" for image-heavy work

# ── Per-user chapter quota (beta rate limit) ─────────────────────────
# Counters are sliding-window over chapter_consumes; admins bypass.
# A "chapter" is consumed by upload+start, /start, /redo. Idle uploads
# and reads are free. Tune for your community size.
#
# [rate_limit]
# chapters_per_hour   = 10
# chapters_per_day    = 50
# concurrent_chapters = 3
