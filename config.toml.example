# Typoon config — Cloudflare AI Gateway + OpenAI compatible

[providers.cf]
type = "openai"
endpoint = "https://gateway.ai.cloudflare.com/v1/11a58966d1289d0387eebba638a19cc3/opencode/openai"
api_key = "cf-gateway"
extra_headers = { cf-aig-authorization = "Bearer cfut_vxNVxasBOzsMzk0kM6fZQ1W8YdYwzzUxD333gfTu6892e253" }

[translation]
provider = "cf"
model = "dynamic/auto"  # Cloudflare Gateway auto-selects best available

[context_agent]
provider = "cf"
model = "dynamic/auto"

# Alternative: direct OpenAI (comment out above, uncomment below)
