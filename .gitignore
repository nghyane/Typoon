__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store

# Local config (per-project)
config.toml

# Models (binary, downloaded separately)
models/
data/

# Cache / benchmark outputs
cache/
logs/
.wrangler/
.antigravitycli/

# Project data (typoon storage, not web routes)
/projects/

# SQLite temp files
*.db
*.db-shm
*.db-wal
debug/
.pipeline/
debug-runs/

# Web UI
web/node_modules/
web/dist/
web/preview/

# Rust build artifacts
target/
crates/*/target/

# Browser extension
ext/node_modules/
ext/.output/
ext/.wxt/
ext/*.zip

# Workspace root (bun symlinks workspace deps here)
/node_modules/

# Secrets
.env
.jwt_secret

# Workspace packages
packages/*/node_modules/
packages/*/dev/assets/*.onnx

# Workers — local dev artifacts (each worker has its own node_modules + .wrangler)
workers/*/node_modules/
workers/*/.wrangler/
workers/*/dist/
workers/*/container/__pycache__/
workers/*/container/.wrangler/
workers/api/.dev.vars
workers/api/r2-cors.json
workers/api/schema-drop.sql
workers/api/worker-configuration.d.ts
# Build outputs that aren't checked in
workers/*/src/*.wasm
workers/*/src/*.wasm.gz
workers/*/wheels/*.whl
workers/*/container/*.whl
workers/*/container/*.onnx
*.so
