__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store

# Local config (per-project)
config.toml

# Models (binary, downloaded separately)
models/
data/

# Cache / benchmark outputs
cache/
logs/

# Project data (typoon storage, not web routes)
/projects/

# SQLite temp files
*.db
*.db-shm
*.db-wal
debug/
.pipeline/
debug-runs/

# Web UI
web/node_modules/
web/dist/
web/preview/

# Rust build artifacts
target/
crates/*/target/

# Browser extension
ext/node_modules/
ext/.output/
ext/.wxt/
ext/*.zip

# Workspace root (bun symlinks workspace deps here)
/node_modules/

# Secrets
.env
.jwt_secret

# Workspace packages
packages/*/node_modules/

# Spike Cloudflare Workers — track source, ignore deps + build artifacts + binaries
spike/node_modules/
spike/*/node_modules/
spike/.wrangler/
spike/*/.wrangler/
spike/*/dist/
spike/*/container/__pycache__/
# Model + wasm artifacts are downloaded/built per spike (see each README)
spike/*/container/*.onnx
spike/*/container/*.bin
spike/*/container/*.safetensors
spike/*/src/*.wasm
spike/*/src/*.wasm.gz
