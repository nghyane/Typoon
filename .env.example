# Typoon environment configuration.
#
# Copy this file to `.env` and fill in the secrets. The engine reads
# these on startup.

# ── Database ────────────────────────────────────────────────────────
# Required. Bring your own Postgres 17 (host install, brew, managed).
# Create the database+role once:
#   createuser -s typoon && createdb -O typoon typoon
DATABASE_URL=postgresql://typoon:typoon@localhost:5432/typoon

# ── Discord OAuth ───────────────────────────────────────────────────
# Create at https://discord.com/developers/applications and add the
# redirect URL to the OAuth2 settings.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Comma-less list, one snowflake. Required if you want to gate by guild.
DISCORD_GUILD_ID=
# Discord user id to promote to tier='admin' on first login. Empty disables.
DISCORD_BOOTSTRAP_ID=

# ── URLs ────────────────────────────────────────────────────────────
# Where the engine API listens (also used to build OAuth redirect_uri).
PUBLIC_API_URL=http://localhost:8000
# Where the web app lives. Engine redirects users here after OAuth.
PUBLIC_WEB_URL=http://localhost:5173

# ── Session ─────────────────────────────────────────────────────────
# Auto-generated to ~/.typoon/.jwt_secret if unset.
# JWT_SECRET=

# ── Inbox (browser-direct chapter uploads) ──────────────────────────
# The web SPA + browser extension push a chapter zip via multipart
# presigned URLs to an S3-compatible inbox bucket so the engine
# avoids serving the upload bandwidth itself. R2 is the recommended
# default (free egress to Cloudflare, free 10 GB storage); any
# S3-compat endpoint works. Bucket needs a 24h lifecycle rule on
# `tmp/` and CORS that exposes the `ETag` response header.
# INBOX_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# INBOX_S3_BUCKET=mangalocal-uploads
# INBOX_S3_REGION=auto
# INBOX_S3_ACCESS_KEY_ID=
# INBOX_S3_SECRET_ACCESS_KEY=
# INBOX_S3_PREFIX=tmp/
